# =====================================================
# PRODMAIS UMC - Configurações de Ambiente
# =====================================================
# Copie este arquivo para .env e ajuste os valores

# -----------------------------------------------------
# BANCO DE DADOS MYSQL
# -----------------------------------------------------
MYSQL_HOST=localhost          # Docker: "db" | Railway/Render: host do plugin MySQL
MYSQL_DB=prodmais_umc
MYSQL_USER=root
MYSQL_PASS=root
MYSQL_ROOT_PASS=root          # Apenas para docker-compose (não enviado à app)
# MYSQL_PORT=3306             # Padrão: 3306

# -----------------------------------------------------
# ELASTICSEARCH (Opcional — app cai para MySQL se não disponível)
# -----------------------------------------------------
# Docker local / OCI: "elasticsearch:9200"
# Bonsai.io free tier: "usuario:senha@meu-cluster.bonsai.io:443"
# Vazio ou inacessível → fallback automático para busca MySQL
ES_HOST=localhost:9200

# -----------------------------------------------------
# ADMIN (credenciais legadas — migrar para AuthManager)
# -----------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=troque-essa-senha-em-producao

# -----------------------------------------------------
# AMBIENTE
# -----------------------------------------------------
APP_ENV=development    # production | development
APP_DEBUG=true         # false em produção
APP_URL=http://localhost:8000
WEB_PORT=8080          # Porta exposta pelo Docker

# -----------------------------------------------------
# INSTITUIÇÃO (UMC)
# -----------------------------------------------------
INSTITUICAO_NOME=Universidade de Mogi das Cruzes
INSTITUICAO_SIGLA=UMC
BRANCH_NAME=PRODMAIS UMC

# -----------------------------------------------------
# SESSÃO E SEGURANÇA
# -----------------------------------------------------
SESSION_LIFETIME=7200  # segundos (2 horas)
SESSION_SECURE=false   # true em produção HTTPS

# -----------------------------------------------------
# UPLOAD DE ARQUIVOS
# -----------------------------------------------------
UPLOAD_MAX_SIZE=10485760  # 10MB em bytes
UPLOAD_DIR=data/uploads

# -----------------------------------------------------
# INTEGRAÇÕES
# -----------------------------------------------------
# OpenAlex API
OPENALEX_EMAIL=seu_email@umc.br

# ORCID (se implementar autenticação)
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=

# -----------------------------------------------------
# CACHE
# -----------------------------------------------------
CACHE_ENABLED=true
CACHE_TTL=3600  # segundos

# -----------------------------------------------------
# LOGS
# -----------------------------------------------------
LOG_LEVEL=debug  # debug | info | warning | error
LOG_DIR=data/logs

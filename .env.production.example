# Configurações de Produção - Prodmais UMC
# Copie este arquivo para .env.production e preencha com os valores reais.
# NUNCA commite o arquivo .env.production com credenciais reais.

# ================================
# BANCO DE DADOS (MySQL)
# ================================
MYSQL_ROOT_PASS=change_me_root_password
MYSQL_DB=prodmais_umc
MYSQL_USER=prodmais_admin
MYSQL_PASS=change_me_app_password

# ================================
# ELASTICSEARCH
# ================================
# Em Docker: elasticsearch:9200
# Em local:  localhost:9200
ELASTICSEARCH_HOST=elasticsearch:9200

# ================================
# CONFIGURAÇÕES DA APLICAÇÃO
# ================================
APP_DEBUG=false
APP_URL=http://your-server-ip:8080
